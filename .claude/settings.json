{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.75"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(curl -sI *)",
      "Bash(curl -s https://*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "hooks/on-git-push.sh" }
        ]
      }
    ]
  },
  "env": {
    "AUDIT_URL": "https://ntfy.pl/"
  }
}
