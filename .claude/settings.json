{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "hooks/on-git-push.sh" }
        ]
      }
    ]
  },
  "env": {
    "AUDIT_URL": "https://ntfy.pl/"
  }
}
